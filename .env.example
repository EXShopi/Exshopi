USE_PRISMA_RUNTIME="true"

# Supabase Postgres (Prisma)
# Replace these placeholders with the exact connection strings from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string
# DATABASE_URL must use the transaction pooler host on port 6543.
# DIRECT_URL must use the direct database host on port 5432.
DATABASE_URL="postgresql://postgres.<your-project-ref>:YOUR_SUPABASE_DB_PASSWORD@<your-region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.<your-project-ref>.supabase.co:5432/postgres"

