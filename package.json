{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx backend/server.ts\" \"vite\"",
    "backend": "tsx backend/server.ts",
    "render:start": "npm run render:start:api",
    "frontend": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "vite build && tsx scripts/generateStaticSeo.ts",
    "build:frontend:strict": "vite build && tsx scripts/generateStaticSeo.ts && tsx scripts/validatePrerenderSeo.ts",
    "build:full": "npm run build:frontend && npm run build:api",
    "build:seo": "tsx scripts/generateStaticSeo.ts && tsx scripts/validatePrerenderSeo.ts",
    "seo:validate": "tsx scripts/validatePrerenderSeo.ts",
    "build:api": "tsc -p backend/tsconfig.json",
    "recover:catalog": "tsx scripts/recoverCatalogFromSnapshots.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "validate:category-assignment": "node --import tsx scripts/validateCategoryAssignment.ts",
    "audit:draft-catalog": "tsx scripts/auditDraftCatalog.ts",
    "apply:draft-catalog-updates": "tsx scripts/applyDraftCatalogUpdates.ts",
    "backfill:country-pricing": "tsx scripts/backfillCountryPricing.ts",
    "start": "node dist/backend/server.js",
    "start:api": "node dist/backend/server.js",
    "render:start:api": "node dist/backend/server.js",
    "start:api:dev": "tsx backend/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "import:products:prisma": "tsx scripts/import_products_prisma.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.16.3",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postcss": "^8.5.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.45.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "prisma": "^6.16.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
