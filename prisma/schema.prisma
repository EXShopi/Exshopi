generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  seller
  admin
  finance_manager
  support_agent
  super_admin
}

enum UserStatus {
  active
  pending
  suspended
}

enum SellerApplicationStatus {
  draft
  pending_review
  approved
  rejected
  needs_more_info
}

enum ProductApprovalStatus {
  pending
  approved
  rejected
}

enum ProductStatus {
  draft
  pending_approval
  live
  rejected
  archived
  out_of_stock
}

enum VisibilityStatus {
  hidden
  live
  archived
}

enum OrderStatus {
  pending
  confirmed
  packed
  shipped
  delivered
  returned
  refunded
  cancelled
}

enum TicketStatus {
  open
  pending
  waiting_for_user
  resolved
  escalated
}

enum WholesaleRequestStatus {
  New       @map("new")
  Contacted @map("contacted")
  Quoted    @map("quoted")
  Confirmed @map("confirmed")
  Cancelled @map("cancelled")
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  passwordHash              String              @map("password_hash")
  name                      String
  phone                     String?
  role                      UserRole
  status                    UserStatus          @default(active)
  country                   String?             @default("AE")
  emailVerified             Boolean             @default(false) @map("email_verified")
  sellerApplicationStatus   SellerApplicationStatus? @map("seller_application_status")
  lastLoginAt               DateTime?           @map("last_login_at")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  sellerApplications        SellerApplication[]
  stores                    Store[]
  products                  Product[]
  customerOrders            Order[]             @relation("CustomerOrders")
  sellerOrders              Order[]             @relation("SellerOrders")
  reviews                   Review[]
  payouts                   Payout[]
  supportTicketsCreated     SupportTicket[]     @relation("TicketCreator")
  supportTicketsAssigned    SupportTicket[]     @relation("TicketAssignee")
  auditLogs                 AuditLog[]

  @@map("users")
}

model SellerApplication {
  id              String                  @id @default(cuid())
  userId          String                  @map("user_id")
  businessName    String                  @map("business_name")
  ownerName       String                  @map("owner_name")
  country         String
  emirate         String?
  city            String
  warehouseAddress String?                @map("warehouse_address")
  vatTrn          String?                 @map("vat_trn")
  iban            String?
  bankName        String?                 @map("bank_name")
  accountHolder   String?                 @map("account_holder")
  about           String?
  status          SellerApplicationStatus @default(draft)
  adminNotes      String?                 @map("admin_notes")
  rejectionReason String?                 @map("rejection_reason")
  reviewedBy      String?                 @map("reviewed_by")
  reviewedAt      DateTime?               @map("reviewed_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  user            User                    @relation(fields: [userId], references: [id])

  @@map("seller_applications")
}

model Store {
  id               String    @id @default(cuid())
  sellerUserId     String    @map("seller_user_id")
  storeName        String    @map("store_name")
  slug             String    @unique
  description      String?
  logoUrl          String?   @map("logo_url")
  bannerUrl        String?   @map("banner_url")
  email            String?
  supportEmail     String?   @map("support_email")
  supportPhone     String?   @map("support_phone")
  supportInfo      String?   @map("support_info")
  website          String?
  country          String?   @default("UAE")
  emirate          String?
  city             String?
  warehouseAddress String?   @map("warehouse_address")
  vatTrn           String?   @map("vat_trn")
  bankName         String?   @map("bank_name")
  bankAccount      String?   @map("bank_account")
  accountHolder    String?   @map("account_holder")
  iban             String?
  policiesJson     Json?     @map("policies_json")
  socialLinksJson  Json?     @map("social_links_json")
  verified         Boolean   @default(false)
  trustScore       Int       @default(0) @map("trust_score")
  isOfficial       Boolean   @default(false) @map("is_official")
  monthlyFeeAed    Int       @default(99) @map("monthly_fee_aed")
  subscriptionStatus String? @default("active") @map("subscription_status")
  status           String    @default("active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sellerUser       User      @relation(fields: [sellerUserId], references: [id])
  products         Product[]
  orders           Order[]

  @@map("stores")
}

model Category {
  id         String    @id @default(cuid())
  parentId   String?   @map("parent_id")
  name       String
  slug       String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  parent     Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]

  @@map("categories")
}

model Product {
  id               String                @id @default(cuid())
  storeId          String                @map("store_id")
  sellerUserId     String                @map("seller_user_id")
  categoryId       String                @map("category_id")
  title            String
  slug             String                @unique
  metaTitle        String?               @map("meta_title")
  metaDescription  String?               @map("meta_description")
  metaKeywords     String?               @map("meta_keywords")
  canonicalUrl     String?               @map("canonical_url")
  ogTitle          String?               @map("og_title")
  ogDescription    String?               @map("og_description")
  ogImage          String?               @map("og_image")
  shortDescription String?               @map("short_description")
  description      String?
  sku              String?
  brand            String?
  price            Decimal               @db.Decimal(12, 2)
  compareAtPrice   Decimal?              @map("compare_at_price") @db.Decimal(12, 2)
  comparePrice     Float?                @map("compare_price")
  priceUae         Decimal?              @map("price_uae") @db.Decimal(12, 2)
  priceKsa         Decimal?              @map("price_ksa") @db.Decimal(12, 2)
  priceQatar       Decimal?              @map("price_qatar") @db.Decimal(12, 2)
  priceKuwait      Decimal?              @map("price_kuwait") @db.Decimal(12, 2)
  priceBahrain     Decimal?              @map("price_bahrain") @db.Decimal(12, 2)
  priceOman        Decimal?              @map("price_oman") @db.Decimal(12, 2)
  originalPrice    Decimal?              @map("original_price") @db.Decimal(12, 2)
  compareAtPriceUae Decimal?             @map("compare_at_price_uae") @db.Decimal(12, 2)
  compareAtPriceKsa Decimal?             @map("compare_at_price_ksa") @db.Decimal(12, 2)
  compareAtPriceQatar Decimal?           @map("compare_at_price_qatar") @db.Decimal(12, 2)
  compareAtPriceKuwait Decimal?          @map("compare_at_price_kuwait") @db.Decimal(12, 2)
  compareAtPriceBahrain Decimal?         @map("compare_at_price_bahrain") @db.Decimal(12, 2)
  compareAtPriceOman Decimal?            @map("compare_at_price_oman") @db.Decimal(12, 2)
  salePrice        Decimal?              @map("sale_price") @db.Decimal(12, 2)
  currency         String                @default("AED")
  stock            Int                   @default(0)
  rating           Float                 @default(0)
  reviewsCount     Int                   @default(0) @map("reviews_count")
  specsJson        Json?                 @map("specs_json")
  specifications   Json?
  pricesByCountry  Json?                 @map("prices_by_country")
  parentCategorySlug String?             @map("parent_category_slug")
  categorySlug     String?               @map("category_slug")
  subcategorySlug  String?               @map("subcategory_slug")
  childCategorySlug String?              @map("child_category_slug")
  categoryPathJson Json?                 @map("category_path_json")
  badgesJson       Json?                 @map("badges_json")
  views            Int                   @default(0)
  wishlistCount    Int                   @default(0) @map("wishlist_count")
  ownership        String?               @default("seller")
  createdByRole    String?               @default("seller") @map("created_by_role")
  approvalRequestedAt DateTime?          @map("approval_requested_at")
  approvalStatus   ProductApprovalStatus @default(pending) @map("approval_status")
  status           ProductStatus         @default(draft)
  visibilityStatus VisibilityStatus      @default(hidden) @map("visibility_status")
  rejectionReason  String?               @map("rejection_reason")
  approvalNotes    String?               @map("approval_notes")
  approvedBy       String?               @map("approved_by")
  approvedAt       DateTime?             @map("approved_at")
  rejectedAt       DateTime?             @map("rejected_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  store            Store                 @relation(fields: [storeId], references: [id])
  sellerUser       User                  @relation(fields: [sellerUserId], references: [id])
  category         Category              @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  orderItems       OrderItem[]
  reviews          Review[]

  @@map("products")
  @@index([slug], name: "idx_products_slug")
  @@index([categorySlug], name: "idx_products_category_slug")
  @@index([parentCategorySlug], name: "idx_products_parent_category_slug")
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  imageUrl   String   @map("image_url")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  product    Product  @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique @map("order_number")
  customerId    String      @map("customer_id")
  storeId       String      @map("store_id")
  sellerUserId  String      @map("seller_user_id")
  subtotal      Decimal     @db.Decimal(12, 2)
  vatAmount     Decimal     @map("vat_amount") @db.Decimal(12, 2)
  deliveryFee   Decimal     @map("delivery_fee") @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount   Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency      String      @default("AED")
  taxRate       Decimal?    @map("tax_rate") @db.Decimal(5, 4)
  paymentMethod String      @map("payment_method")
  paymentProvider String?   @map("payment_provider")
  paymentStatus String      @map("payment_status")
  paymentReference String?  @map("payment_reference")
  paymentSessionId String?  @map("payment_session_id")
  paidAt        DateTime?   @map("paid_at")
  payoutStatus  String      @default("pending") @map("payout_status")
  commissionAmount Decimal  @default(0) @map("commission_amount") @db.Decimal(12, 2)
  sellerAmount  Decimal     @default(0) @map("seller_amount") @db.Decimal(12, 2)
  status        OrderStatus @default(pending)
  customerName  String?     @map("customer_name")
  customerEmail String?     @map("customer_email")
  customerPhone String?     @map("customer_phone")
  shippingAddressJson Json? @map("shipping_address_json")
  deliveryCountry String?   @map("delivery_country")
  deliveryEta   String?     @map("delivery_eta")
  refundStatus  String?     @default("none") @map("refund_status")
  refundReason  String?     @map("refund_reason")
  refundAmount  Decimal?    @map("refund_amount") @db.Decimal(12, 2)
  dispatchSlotDate DateTime? @map("dispatch_slot_date")
  dispatchSlotWindow String? @map("dispatch_slot_window")
  dispatchNotes String?     @map("dispatch_notes")
  courierPartner String?    @map("courier_partner")
  trackingCode  String?     @map("tracking_code")
  pickupQrCode  String?     @map("pickup_qr_code")
  emirate       String?
  area          String?
  building      String?
  flat          String?
  addressLine   String?     @map("address_line")
  placedAt      DateTime    @default(now()) @map("placed_at")
  deliveredAt   DateTime?   @map("delivered_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  customer      User        @relation("CustomerOrders", fields: [customerId], references: [id])
  sellerUser    User        @relation("SellerOrders", fields: [sellerUserId], references: [id])
  store         Store       @relation(fields: [storeId], references: [id])
  items         OrderItem[]
  trackingEvents TrackingEvent[]

  @@map("orders")
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String   @map("order_id")
  productId        String   @map("product_id")
  productTitle     String   @map("product_title")
  sku              String?
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  salePrice        Decimal? @map("sale_price") @db.Decimal(12, 2)
  compareAtPrice   Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  priceSnapshotCountry String? @map("price_snapshot_country")
  priceSnapshotCurrency String? @map("price_snapshot_currency")
  quantity         Int
  vatAmount        Decimal  @map("vat_amount") @db.Decimal(12, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(12, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(12, 2)
  sellerNetAmount  Decimal  @map("seller_net_amount") @db.Decimal(12, 2)
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")

  order            Order    @relation(fields: [orderId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])
  reviews          Review[]

  @@map("order_items")
}

model WholesaleRequest {
  id                String                 @id @default(cuid())
  fullName          String                 @map("full_name")
  phone             String
  email             String
  country           String
  city              String
  productCategory   String                 @map("product_category")
  productName       String                 @map("product_name")
  modelsRequired    String                 @map("models_required")
  quantity          Int
  expectedPrice     String?                @map("expected_price")
  conditionRequired String                 @default("any") @map("condition_required")
  deliveryCountry   String                 @map("delivery_country")
  deliveryAddress   String                 @map("delivery_address")
  notes             String?
  status            WholesaleRequestStatus @default(New)
  adminNotes        String?                @map("admin_notes")
  source            String                 @default("website")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  @@map("wholesale_requests")
}

model Review {
  id               String   @id @default(cuid())
  orderItemId      String   @map("order_item_id")
  productId        String   @map("product_id")
  customerId       String   @map("customer_id")
  sellerUserId     String   @map("seller_user_id")
  rating           Int
  title            String?
  comment          String?
  verifiedPurchase Boolean  @default(true) @map("verified_purchase")
  sellerReply      String?  @map("seller_reply")
  sellerRepliedAt  DateTime? @map("seller_replied_at")
  createdAt        DateTime @default(now()) @map("created_at")

  orderItem        OrderItem @relation(fields: [orderItemId], references: [id])
  product          Product   @relation(fields: [productId], references: [id])
  customer         User      @relation(fields: [customerId], references: [id])

  @@map("reviews")
}

model Payout {
  id              String   @id @default(cuid())
  sellerUserId    String   @map("seller_user_id")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  grossSales      Decimal  @map("gross_sales") @db.Decimal(12, 2)
  commissionTotal Decimal  @map("commission_total") @db.Decimal(12, 2)
  refundDeductions Decimal @map("refund_deductions") @db.Decimal(12, 2)
  netPayout       Decimal  @map("net_payout") @db.Decimal(12, 2)
  status          String   @default("pending")
  paidAt          DateTime? @map("paid_at")
  bankReference   String?  @map("bank_reference")
  createdAt       DateTime @default(now()) @map("created_at")

  sellerUser      User     @relation(fields: [sellerUserId], references: [id])

  @@map("payouts")
}

model PayoutRequest {
  id              String   @id @default(cuid())
  sellerUserId    String   @map("seller_user_id")
  amount          Decimal  @db.Decimal(12, 2)
  status          String   @default("pending")
  notes           String?
  bankDetailsJson Json?    @map("bank_details_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("payout_requests")
}

model SupportTicket {
  id            String       @id @default(cuid())
  createdById    String?      @map("created_by_id")
  createdByRole  String?      @map("created_by_role")
  customerId    String?      @map("customer_id")
  sellerUserId  String?      @map("seller_user_id")
  orderId       String?      @map("order_id")
  productId     String?      @map("product_id")
  payoutRequestId String?    @map("payout_request_id")
  subject       String
  description   String
  priority      String       @default("normal")
  status        TicketStatus @default(open)
  assignedTo    String?      @map("assigned_to")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  creator       User?        @relation("TicketCreator", fields: [customerId], references: [id])
  assignee      User?        @relation("TicketAssignee", fields: [assignedTo], references: [id])
  messages      SupportTicketMessage[]

  @@map("support_tickets")
}

model SupportTicketMessage {
  id            String   @id @default(cuid())
  ticketId      String   @map("ticket_id")
  senderId      String   @map("sender_id")
  senderRole    String   @map("sender_role")
  message       String
  attachmentUrl String?  @map("attachment_url")
  createdAt     DateTime @default(now()) @map("created_at")

  ticket        SupportTicket @relation(fields: [ticketId], references: [id])

  @@map("support_ticket_messages")
}

model TrackingEvent {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  status     String
  timestamp  DateTime
  notes      String?
  location   String?
  createdAt  DateTime @default(now()) @map("created_at")

  order      Order    @relation(fields: [orderId], references: [id])

  @@map("tracking_events")
}

model Setting {
  id         String   @id @default(cuid())
  key        String   @unique
  valueJson  Json     @map("value_json")
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?  @map("actor_id")
  actorRole    String   @map("actor_role")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  action       String
  metadataJson Json?    @map("metadata_json")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  actor        User?    @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}
